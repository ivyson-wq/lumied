{
  "buildCommand": "bash build.sh",
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "admin.lumied.com.br" }],
      "destination": "/admin-central.html",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.lumied.com.br" }],
      "destination": "https://lumied.com.br/",
      "permanent": true
    },
    {
      "source": "/site",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "https://lumied.com.br/",
      "permanent": true
    },
    {
      "source": "/site/",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "https://lumied.com.br/",
      "permanent": true
    },
    {
      "source": "/site/:path*",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "https://lumied.com.br/:path*",
      "permanent": true
    },
    {
      "source": "/familia.html",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "https://lumied.com.br/",
      "permanent": true
    },
    {
      "source": "/index.html",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "https://lumied.com.br/",
      "permanent": true
    },
    {
      "source": "/area-restrita.html",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "https://lumied.com.br/",
      "permanent": true
    },
    {
      "source": "/gerente.html",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "https://lumied.com.br/",
      "permanent": true
    },
    {
      "source": "/professora.html",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "https://lumied.com.br/",
      "permanent": true
    },
    {
      "source": "/secretaria.html",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "https://lumied.com.br/",
      "permanent": true
    },
    {
      "source": "/aluno.html",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "https://lumied.com.br/",
      "permanent": true
    },
    {
      "source": "/admin.html",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "https://lumied.com.br/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/index.html"
    },
    {
      "source": "/blog/blog-cta.js",
      "destination": "/site/blog/blog-cta.js"
    },
    {
      "source": "/blog",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/blog/index.html"
    },
    {
      "source": "/blog/",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/blog/index.html"
    },
    {
      "source": "/blog/:slug",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/blog/:slug/index.html"
    },
    {
      "source": "/blog/:slug/",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/blog/:slug/index.html"
    },
    {
      "source": "/sobre",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/sobre/index.html"
    },
    {
      "source": "/sobre/",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/sobre/index.html"
    },
    {
      "source": "/clientes/:path*",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/clientes/:path*"
    },
    {
      "source": "/dpa/:path*",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/dpa/:path*"
    },
    {
      "source": "/privacidade/:path*",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/privacidade/:path*"
    },
    {
      "source": "/sla/:path*",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/sla/:path*"
    },
    {
      "source": "/status/:path*",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/status/:path*"
    },
    {
      "source": "/termos/:path*",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/termos/:path*"
    },
    {
      "source": "/vs/:path*",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/vs/:path*"
    },
    {
      "source": "/videos/:path*",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/videos/:path*"
    },
    {
      "source": "/screenshots/:path*",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/screenshots/:path*"
    },
    {
      "source": "/certificacao",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/certificacao.html"
    },
    {
      "source": "/certificacao.html",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/certificacao.html"
    },
    {
      "source": "/instagram-templates",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/instagram-templates.html"
    },
    {
      "source": "/instagram-templates.html",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/instagram-templates.html"
    },
    {
      "source": "/whatsapp-float.js",
      "has": [{ "type": "host", "value": "lumied.com.br" }],
      "destination": "/site/whatsapp-float.js"
    },
    {
      "source": "/",
      "destination": "/familia.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(), geolocation=(self), payment=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://browser.sentry-cdn.com https://js.sentry-cdn.com https://cdn.jsdelivr.net https://cdn.sheetjs.com https://www.googletagmanager.com https://www.google-analytics.com https://ssl.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co https://images.unsplash.com https://www.google-analytics.com https://www.googletagmanager.com https://img.youtube.com; connect-src 'self' https://*.supabase.co https://*.sentry.io https://*.ingest.us.sentry.io https://www.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://region1.google-analytics.com; frame-src https://www.youtube.com https://www.youtube-nocookie.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" }
      ]
    }
  ]
}
