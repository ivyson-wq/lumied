# ─── Identidade da escola (obrigatório) ───────────────────────────
LUMIED_ESCOLA_ID=00000000-0000-0000-0000-000000000000
LUMIED_BRIDGE_TOKEN=lbr_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Gateway (default já aponta pro Lumied prod) ──────────────────
LUMIED_GATEWAY_URL=wss://lumied-bridge-gateway.ivyson.workers.dev

# ─── Credenciais iDFace ───────────────────────────────────────────
# Login compartilhado entre todos os dispositivos da escola.
IDFACE_LOGIN=admin
IDFACE_PASSWORD=

# Override por IP (JSON), opcional. Ex.:
# IDFACE_PASSWORDS={"192.168.1.10":"senha1","192.168.1.11":"senha2"}
IDFACE_PASSWORDS=

# ─── Servidor HTTP local (recebe callbacks dos iDFace) ────────────
EVENT_LISTENER_PORT=8765
# IP local que será informado aos iDFace como callback URL.
# Deixe em branco para auto-detectar o IP da LAN.
EVENT_LISTENER_HOST=

# ─── Logs ─────────────────────────────────────────────────────────
LOG_LEVEL=info
