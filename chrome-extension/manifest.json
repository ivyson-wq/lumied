{
  "manifest_version": 3,
  "name": "Lumied CRM - WhatsApp Templates",
  "version": "1.4.0",
  "description": "Envie templates e capture leads do CRM escolar Lumied diretamente no WhatsApp Web. Gerencie comunicacao com familias e pipeline comercial.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://web.whatsapp.com/*", "https://brgorknbrjlfwvrrlwxj.supabase.co/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [{
    "matches": ["https://web.whatsapp.com/*"],
    "js": ["content.js"],
    "css": ["content.css"]
  }],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [{
    "resources": ["lumied-icon.png"],
    "matches": ["https://web.whatsapp.com/*"]
  }]
}
