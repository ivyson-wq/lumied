{
  "manifest_version": 3,
  "name": "Lumied CRM - WhatsApp Templates",
  "version": "1.1.0",
  "description": "Envie templates de mensagens do CRM escolar Lumied diretamente no WhatsApp Web. Gerencie comunicacao com familias de forma rapida e padronizada.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [{
    "matches": ["https://web.whatsapp.com/*"],
    "js": ["content.js"],
    "css": ["content.css"]
  }],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
